# Copy this file to .env and adjust the values:
#   cp .env.example .env
# Real environment variables override .env. The .env file is git-ignored.

# App
ENV=development
# HOST empty = bind all interfaces (0.0.0.0), reachable from other devices on the LAN.
# Set to 127.0.0.1 to restrict the server to localhost only.
HOST=
PORT=8080

# Database connection string (PostgreSQL).
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/openaiq?sslmode=disable

# Connection pool tuning.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
