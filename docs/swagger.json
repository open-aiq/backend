{
    "swagger": "2.0",
    "info": {
        "description": "Air quality monitoring API",
        "title": "Air Quality API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/air-quality/current": {
            "get": {
                "description": "Returns the latest air quality reading",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Air Quality"
                ],
                "summary": "Get current air quality",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/airquality.CurrentResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/airquality.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/air-quality/custom": {
            "get": {
                "description": "Returns air quality data points between start_date and end_date",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Air Quality"
                ],
                "summary": "Get air quality data for a custom date range",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Start date (YYYY-MM-DD)",
                        "name": "start_date",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "End date (YYYY-MM-DD)",
                        "name": "end_date",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/airquality.CustomRangeResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/airquality.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/airquality.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/air-quality/historical": {
            "get": {
                "description": "Returns historical air quality data aggregated by timeline",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Air Quality"
                ],
                "summary": "Get historical air quality data",
                "parameters": [
                    {
                        "enum": [
                            "daily",
                            "weekly",
                            "monthly",
                            "yearly"
                        ],
                        "type": "string",
                        "description": "Timeline",
                        "name": "timeline",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/airquality.HistoricalResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/airquality.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/airquality.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/devices": {
            "get": {
                "description": "Returns all registered devices. Secret keys are never included.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Devices"
                ],
                "summary": "List all devices",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/device.ListDevicesResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/device.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Registers a device and returns its credentials. The device_key is a secret shown only once here; store it securely.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Devices"
                ],
                "summary": "Register a new device",
                "parameters": [
                    {
                        "description": "Device to register",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/device.CreateDeviceRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/device.CreateDeviceResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/device.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/device.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/devices/{id}": {
            "delete": {
                "description": "Permanently deletes a device by its id.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Devices"
                ],
                "summary": "Delete a device",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device id (UUID)",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/device.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/device.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/device.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "airquality.AirQuality": {
            "type": "object",
            "properties": {
                "aqi": {
                    "type": "integer"
                },
                "pm10_0": {
                    "type": "number"
                },
                "pm1_0": {
                    "type": "number"
                },
                "pm2_5": {
                    "type": "number"
                }
            }
        },
        "airquality.CurrentResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/airquality.AirQuality"
                }
            }
        },
        "airquality.CustomRangeResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/airquality.DataPoint"
                    }
                }
            }
        },
        "airquality.DataPoint": {
            "type": "object",
            "properties": {
                "label": {
                    "type": "string"
                },
                "metrics": {
                    "$ref": "#/definitions/airquality.AirQuality"
                },
                "timestamp": {
                    "type": "string"
                }
            }
        },
        "airquality.ErrorResponse": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "string",
                    "example": "timeline is required"
                },
                "error": {
                    "type": "string",
                    "example": "Missing or invalid query parameters"
                }
            }
        },
        "airquality.HistoricalResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/airquality.DataPoint"
                    }
                },
                "timeline": {
                    "type": "string",
                    "example": "daily"
                }
            }
        },
        "device.CreateDeviceRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "example": "Living Room Sensor"
                }
            }
        },
        "device.CreateDeviceResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/device.CreatedDevice"
                }
            }
        },
        "device.CreatedDevice": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "device_id": {
                    "type": "string",
                    "example": "dev_9f1c8a3b4d2e4f0a5b6c7d8e9f001122"
                },
                "device_key": {
                    "type": "string",
                    "example": "sk_1a2b3c4d5e6f...store this now, it won't be shown again"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string",
                    "example": "Living Room Sensor"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "device.Device": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "device_id": {
                    "type": "string",
                    "example": "dev_9f1c8a3b4d2e4f0a5b6c7d8e9f001122"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string",
                    "example": "Living Room Sensor"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "device.ErrorResponse": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "string",
                    "example": "name is required"
                },
                "error": {
                    "type": "string",
                    "example": "Invalid request body"
                }
            }
        },
        "device.ListDevicesResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/device.Device"
                    }
                }
            }
        }
    }
}